<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/energy_coordinator">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/topAppBar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/title_activity_energy"
            app:navigationIcon="?attr/homeAsUpIndicator"
            style="@style/Widget.Material3.Toolbar.Surface" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Tool 1: Ley de Ohm -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="1. Ley de Ohm" android:textStyle="bold" android:textSize="18sp" android:layout_marginBottom="8dp"/>
                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Voltaje (V)">
                        <com.google.android.material.textfield.TextInputEditText android:maxLength="8" android:maxLines="1" android:id="@+id/etOhmVoltage" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Corriente (A)">
                        <com.google.android.material.textfield.TextInputEditText android:maxLength="8" android:maxLines="1" android:id="@+id/etOhmCurrent" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnCalcOhm" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Calcular Resistencia (Ω)" style="@style/Widget.Material3.Button.TonalButton"/>
                    <TextView android:id="@+id/tvOhmResult" android:layout_width="match_parent" android:layout_height="wrap_content" android:textStyle="bold" android:textAlignment="center"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tool 2: Potencia -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="2. Calculadora de Potencia" android:textStyle="bold" android:textSize="18sp" android:layout_marginBottom="8dp"/>
                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Voltaje (V)">
                        <com.google.android.material.textfield.TextInputEditText android:maxLength="8" android:maxLines="1" android:id="@+id/etPowerVoltage" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Corriente (A)">
                        <com.google.android.material.textfield.TextInputEditText android:maxLength="8" android:maxLines="1" android:id="@+id/etPowerCurrent" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnCalcPower" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Calcular Potencia (W)" style="@style/Widget.Material3.Button.TonalButton"/>
                    <TextView android:id="@+id/tvPowerResult" android:layout_width="match_parent" android:layout_height="wrap_content" android:textStyle="bold" android:textAlignment="center"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tool 3: Caida de Tension -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="3. Caída de Tensión (Cobre)" android:textStyle="bold" android:textSize="18sp" android:layout_marginBottom="8dp"/>
                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Longitud (metros)">
                        <com.google.android.material.textfield.TextInputEditText android:maxLength="8" android:maxLines="1" android:id="@+id/etDropLength" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Corriente (A)">
                        <com.google.android.material.textfield.TextInputEditText android:maxLength="8" android:maxLines="1" android:id="@+id/etDropCurrent" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Sección (mm²)">
                        <com.google.android.material.textfield.TextInputEditText android:maxLength="8" android:maxLines="1" android:id="@+id/etDropArea" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnCalcDrop" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Calcular Caída (V)" style="@style/Widget.Material3.Button.TonalButton"/>
                    <TextView android:id="@+id/tvDropResult" android:layout_width="match_parent" android:layout_height="wrap_content" android:textStyle="bold" android:textAlignment="center"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tool 4: Cables -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="4. Calibre de Cable (Cobre 75°C)" android:textStyle="bold" android:textSize="18sp" android:layout_marginBottom="8dp"/>
                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Corriente Máxima (A)">
                        <com.google.android.material.textfield.TextInputEditText android:maxLength="8" android:maxLines="1" android:id="@+id/etCableCurrent" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnCalcCable" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Sugerir Calibre AWG" style="@style/Widget.Material3.Button.TonalButton"/>
                    <TextView android:id="@+id/tvCableResult" android:layout_width="match_parent" android:layout_height="wrap_content" android:textStyle="bold" android:textAlignment="center"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tool 5: Capacitor -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="5. Energía de Capacitor" android:textStyle="bold" android:textSize="18sp" android:layout_marginBottom="8dp"/>
                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Capacitancia (Microfaradios μF)">
                        <com.google.android.material.textfield.TextInputEditText android:maxLength="8" android:maxLines="1" android:id="@+id/etCapCapacitance" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Voltaje (V)">
                        <com.google.android.material.textfield.TextInputEditText android:maxLength="8" android:maxLines="1" android:id="@+id/etCapVoltage" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnCalcCap" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Calcular Energía (Joules)" style="@style/Widget.Material3.Button.TonalButton"/>
                    <TextView android:id="@+id/tvCapResult" android:layout_width="match_parent" android:layout_height="wrap_content" android:textStyle="bold" android:textAlignment="center"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tool 6: Costo -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="6. Costo de Consumo" android:textStyle="bold" android:textSize="18sp" android:layout_marginBottom="8dp"/>
                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Potencia del equipo (Watts)">
                        <com.google.android.material.textfield.TextInputEditText android:maxLength="8" android:maxLines="1" android:id="@+id/etCostPower" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Horas de uso al día">
                        <com.google.android.material.textfield.TextInputEditText android:maxLength="8" android:maxLines="1" android:id="@+id/etCostTime" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Costo por kWh ($)">
                        <com.google.android.material.textfield.TextInputEditText android:maxLength="8" android:maxLines="1" android:id="@+id/etCostRate" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnCalcCost" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Calcular Costo Mensual" style="@style/Widget.Material3.Button.TonalButton"/>
                    <TextView android:id="@+id/tvCostResult" android:layout_width="match_parent" android:layout_height="wrap_content" android:textStyle="bold" android:textAlignment="center"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
