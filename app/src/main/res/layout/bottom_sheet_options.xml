<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bottom_sheet_background">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/options_title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/options_language"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLanguageSelector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/options_language"
        android:layout_marginBottom="24dp"
        app:icon="@drawable/ic_language"
        style="@style/Widget.Material3.Button" />

    <com.google.android.material.button.MaterialButton

        android:id="@+id/btnRemoveAds"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/options_remove_ads"
        android:layout_marginBottom="16dp"
        app:icon="@android:drawable/ic_menu_close_clear_cancel"
        style="@style/Widget.Material3.Button.TonalButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRateApp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/options_rate_app"
        android:layout_marginBottom="16dp"
        app:icon="@drawable/ic_star"
        style="@style/Widget.Material3.Button.TextButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAbout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/menu_about"
        app:icon="@drawable/ic_info"
        style="@style/Widget.Material3.Button.TextButton" />

</LinearLayout>